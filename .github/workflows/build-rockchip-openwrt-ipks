name: build-openwrt-ipks

on:
  workflow_dispatch:
    inputs:
      version:
        type: choice
        description: '输入OpenWrt版本，可选值如下：'
        options:
          - v24.10.7
          - v25.12.5
        required: true
        default: 'v24.10.7'
      profile:
        type: choice
        description: '输入软路由型号，可选值如下：'
        options:
          - friendlyarm_nanopi-r2s
        required: true
        default: 'friendlyarm_nanopi-r2s'

jobs:
  build:
    runs-on: ubuntu-22.04
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      
      - name: Set up OpenWRT build environment
        run: |
          sudo apt-get update
          sudo apt-get upgrade
          sudo apt-get install build-essential clang flex bison g++ gawk \
          gcc-multilib g++-multilib gettext git libncurses-dev libssl-dev \
          python3-distutils python3-setuptools python3-pip python3-dev python3-pyelftools \
          rsync swig unzip zlib1g-dev file wget
          sudo apt-get autoclean
          sudo apt-get autoremove
      
      - name: Clone OpenWRT source code
        run: |
          CHECKOUT_TAG=${{ inputs.version }}
          git clone --depth 1 --branch $CHECKOUT_TAG --single-branch https://github.com/openwrt/openwrt.git
          echo "Using version: $CHECKOUT_TAG"
      
      - name: Customize packages
        run: |
          cd openwrt
          
          # git clone https://github.com/stackia/rtp2httpd.git
          # cd rtp2httpd
          # 用预生成的 Makefile 替换原始 Makefile（已包含固定版本号、源码下载地址和 PKG_HASH）
          # mv openwrt-support/rtp2httpd/Makefile.versioned openwrt-support/rtp2httpd/Makefile
          # mv openwrt-support/luci-app-rtp2httpd/Makefile.versioned openwrt-support/luci-app-rtp2httpd/Makefile
          # 将 openwrt-support 目录内容复制到你的 feeds 仓库
          # cp -r openwrt-support/* ../package/

          # cd ..
          
          # git clone --depth=1 --branch master https://github.com/vernesong/OpenClash.git package/luci-app-openclash
          # rm -rf package/luci-app-openclash/.git
          
          # git clone https://github.com/jerrykuku/luci-theme-argon.git package/luci-theme-argon
          # git clone https://github.com/jerrykuku/luci-app-argon-config.git package/luci-app-argon-config
          git clone https://github.com/gdy666/luci-app-lucky.git package/lucky
          cp ${{ github.workspace }}/package/lucky/Makefile package/lucky/lucky/Makefile
      
      - name: Update and install the feeds
        run: |
          cd openwrt
          
          ./scripts/feeds update -a
          ./scripts/feeds install -a
      
      - name: Copy pre-existing .config file
        run: |
          cd openwrt
          cp ${{ github.workspace }}/imm/rockchip-r2s/imm.config .config
          make defconfig
      
      - name: Download build files
        run: |
          cd openwrt
          make download -j$(nproc)
      
      - name: Building lucky
        run: |
          cd openwrt
          # 编译lucky IPK包
          make package/lucky/lucky/compile V=s
          # 编译luci-app-lucky IPK包
          make package/lucky/luci-app-lucky/compile V=s
      
      - name: Generate release tag
        run: |
          echo "RELEASE_TAG=$(date +'%Y%m%d-%H%M')" >> $GITHUB_ENV
      
      - name: Release ipk
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ipk-${{ github.run_number }}
          name: OpenWrt packages ${{ github.run_number }}
          files: |
            openwrt/bin/packages/**/*.ipk
          env:
            GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
